{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CatProfile",
  "type": "object",
  "required": ["id", "name", "location", "tnr_status"],
  "properties": {
    "id": { "type": "string", "description": "Unique identifier" },
    "name": { "type": "string" },
    "species": { "type": "string" },
    "breed": { "type": "string" },
    "color": { "type": "string" },
    "gender": { "type": "string", "enum": ["公", "母", "未知"] },
    "estimated_age": { "type": ["number", "null"] },
    "weight": { "type": ["number", "null"] },
    "location": { "type": "string", "description": "Location tag e.g. #23" },
    "status": { "type": "string", "description": "Current status e.g. 已放归" },
    "personality": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Traits e.g. aggressive, friendly, shy"
    },
    "tnr_status": { "type": "boolean", "description": "Trap-Neuter-Return done" },
    "image_url": { "type": "string", "format": "uri" },
    "embedding_id": { "type": "string", "description": "Reference key into cat_profiles.pkl" },
    "notes": { "type": "string" },
    "click_count": { "type": "integer", "default": 0 },
    "likes_count": { "type": "integer", "default": 0 },
    "comments_count": { "type": "integer", "default": 0 },
    "favorites_count": { "type": "integer", "default": 0 }
  }
}
