# --- 机器学习模型 (最关键，防止 7.5GB 再次触发错误) ---
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.model
# 如果你的模型在某个特定文件夹里，比如 models/
model_save/


# --- 图片数据 (GitHub 不适合存大量图片) ---
campus_cats_library/
images/
# --- Python 缓存与环境 ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.env

# --- 数据库与指纹库 ---
*.pkl
*.db
*.sqlite

# --- 操作系统临时文件 ---
.DS_Store
Thumbs.db



# ── Next.js / Node ────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
